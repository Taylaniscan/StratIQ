# StratIQ environment variables — copy to .env.local and fill in.
# Never commit .env.local. Keep real secrets out of this file.

# --- Supabase (auth + storage + Postgres) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Database (Prisma) ---
# DATABASE_URL = runtime connection. Use the dedicated, NON-BYPASSRLS app role
#   (created by `npm run db:setup-rls`), pooled (pgbouncer, :6543), so Postgres
#   RLS is actually enforced. e.g. postgresql://stratiq_app.<ref>:<pw>@<host>:6543/postgres?pgbouncer=true
# DIRECT_URL = privileged `postgres` role, direct (:5432). Used for migrations,
#   the RLS setup script, and the admin client. e.g. postgresql://postgres.<ref>:<pw>@<host>:5432/postgres
DATABASE_URL=
DIRECT_URL=

# --- AI provider (§10) ---
# AI_PROVIDER selects the backend: "gemini" (default, free build tier) or "anthropic".
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

// StratIQ Prisma schema.
// See CLAUDE.md §6 for the full target data model. This first migration lays
// down the foundational identity + tenancy tables only; domain entities
// (EvidenceCard, SpendLine, StrategyOption, ...) and Postgres RLS policies
// arrive in their own tasks.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (pgbouncer) for the app at runtime.
  url       = env("DATABASE_URL")
  // Direct connection (port 5432) for migrations / introspection.
  directUrl = env("DIRECT_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum OrgTier {
  SMALL
  MID
  ENTERPRISE
}

// Superset covering the SMALL collapsed set (OWNER/MEMBER/VIEWER) and the full
// enterprise role matrix (CLAUDE.md §5). The Adaptivity Engine decides which of
// these are actually exposed per profile.
enum Role {
  OWNER
  MEMBER
  VIEWER
  TENANT_ADMIN
  CPO
  CATEGORY_MANAGER
  ANALYST
  FINANCE_APPROVER
  STAKEHOLDER
  LEGAL_COMPLIANCE
  SUPPLIER_USER
}

enum WorkspaceStatus {
  DRAFT
  REVIEW
  APPROVED
  IN_EXECUTION
  MONITORING
  REFRESH
}

enum Confidence {
  HIGH
  MEDIUM
  LOW
}

enum DataQuality {
  COMPLETE
  PARTIAL
  STALE
  ESTIMATED
  BLOCKED
}

enum Freshness {
  FRESH
  AGING
  STALE
}

// ---------------------------------------------------------------------------
// Identity & tenancy (foundation)
// ---------------------------------------------------------------------------

model Tenant {
  id        String   @id @default(cuid())
  name      String
  orgTier   OrgTier  @default(SMALL)
  createdAt DateTime @default(now())

  users       User[]
  memberships Membership[]
  workspaces  Workspace[]
  suppliers   Supplier[]

  @@map("tenants")
}

model User {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  // Supabase auth user id (auth.users.id). Links the app user to the auth user.
  authUserId String? @unique @map("auth_user_id")
  email     String
  name      String?
  createdAt DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model Membership {
  id       String @id @default(cuid())
  tenantId String @map("tenant_id")
  userId   String @map("user_id")
  role     Role   @default(MEMBER)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("memberships")
}

// ---------------------------------------------------------------------------
// Category workspaces
// ---------------------------------------------------------------------------

model Workspace {
  id         String          @id @default(cuid())
  tenantId   String          @map("tenant_id")
  name       String
  objective  String?
  taxonomyL1 String          @map("taxonomy_l1")
  taxonomyL2 String?         @map("taxonomy_l2")
  taxonomyL3 String?         @map("taxonomy_l3")
  // ContextProfile (drives the Adaptivity Engine). Stored as JSON; validated by
  // lib/adaptivity/profile.ts before persistence.
  profile    Json
  status     WorkspaceStatus @default(DRAFT)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant        Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spendDatasets SpendDataset[]
  spendLines    SpendLine[]
  requirements  RequirementArtifact[]
  evidenceCards EvidenceCard[]

  @@index([tenantId])
  @@map("workspaces")
}

// ---------------------------------------------------------------------------
// Audit log (append-only — see scripts/db/setup-rls.mjs which revokes
// UPDATE/DELETE for the app role)
// ---------------------------------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  actorId   String   @map("actor_id")
  action    String
  entity    String
  entityId  String   @map("entity_id")
  payload   Json?
  at        DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, entity, entityId])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Spend & Contract Data Fabric (M2)
// ---------------------------------------------------------------------------

model Supplier {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  name        String
  isIncumbent Boolean  @default(false) @map("is_incumbent")
  tier        String?
  riskProfile Json?    @map("risk_profile")
  esgProfile  Json?    @map("esg_profile")
  createdAt   DateTime @default(now()) @map("created_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  spendLines SpendLine[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("suppliers")
}

model SpendDataset {
  id            String      @id @default(cuid())
  tenantId      String      @map("tenant_id")
  workspaceId   String      @map("workspace_id")
  filename      String
  status        DataQuality @default(COMPLETE)
  rowCount      Int         @default(0) @map("row_count")
  errorCount    Int         @default(0) @map("error_count")
  totalMinor    BigInt      @default(0) @map("total_minor")
  currency      String?
  periodStart   DateTime?   @map("period_start")
  periodEnd     DateTime?   @map("period_end")
  uploadedById  String      @map("uploaded_by_id")
  createdAt     DateTime    @default(now()) @map("created_at")

  workspace  Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  spendLines SpendLine[]

  @@index([tenantId])
  @@index([workspaceId])
  @@map("spend_datasets")
}

model SpendLine {
  id                       String      @id @default(cuid())
  tenantId                 String      @map("tenant_id")
  workspaceId              String      @map("workspace_id")
  datasetId                String      @map("dataset_id")
  supplierId               String?     @map("supplier_id")
  buUnit                   String?     @map("bu_unit")
  site                     String?
  glDate                   DateTime    @map("gl_date")
  amountMinor              BigInt      @map("amount_minor")
  currency                 String
  classification           String?
  classificationConfidence Confidence? @map("classification_confidence")
  contractId               String?     @map("contract_id")
  isMaverick               Boolean     @default(false) @map("is_maverick")

  workspace Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dataset   SpendDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  supplier  Supplier?    @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([workspaceId])
  @@index([datasetId])
  @@map("spend_lines")
}

// ---------------------------------------------------------------------------
// Requirements & Demand Intelligence (M3)
// ---------------------------------------------------------------------------

model RequirementArtifact {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  workspaceId String   @map("workspace_id")
  // e.g. "INTAKE" — archetype-shaped, keyed by Capabilities.requirementFields.
  kind        String
  data        Json
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, kind])
  @@index([tenantId])
  @@map("requirement_artifacts")
}

// ---------------------------------------------------------------------------
// Market & Supplier Intelligence — EvidenceCard trust spine (M4)
// ---------------------------------------------------------------------------

model EvidenceCard {
  id                 String     @id @default(cuid())
  tenantId           String     @map("tenant_id")
  workspaceId        String     @map("workspace_id")
  claim              String
  // EvidenceKind-style tag used to satisfy evidencePolicy.requiredCards.
  category           String?
  sourceType         String     @map("source_type")
  sourceRef          String?    @map("source_ref")
  sourceUrl          String?    @map("source_url")
  collectedAt        DateTime   @map("collected_at")
  refreshedAt        DateTime?  @map("refreshed_at")
  // Snapshot at write time; the live value is derived from collectedAt + recency.
  freshness          Freshness  @default(FRESH)
  confidence         Confidence @default(MEDIUM)
  triangulationCount Int        @default(1) @map("triangulation_count")
  ownerId            String     @map("owner_id")
  createdAt          DateTime   @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([workspaceId])
  @@map("evidence_cards")
}
